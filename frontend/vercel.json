{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",

  "functions": {
    "api/analyze.py": {
      "maxDuration": 30
    },
    "api/chat.py": {
      "maxDuration": 30
    }
  },

  "routes": [
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.py",
      "methods": ["POST"]
    },
    {
      "src": "/api/health",
      "dest": "/api/analyze.py",
      "methods": ["GET"]
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.py",
      "methods": ["POST", "OPTIONS"]
    }
  ]
}

